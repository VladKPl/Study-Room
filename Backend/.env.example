DATABASE_URL=postgresql://<user>:<password>@localhost:5432/studyroom
TEST_DATABASE_URL=postgresql://<user>:<password>@localhost:5432/studyroom_test
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=<long-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_HOURS=36

GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback
FRONTEND_GOOGLE_SUCCESS_REDIRECT_URL=http://127.0.0.1:5173/auth/google/callback
FRONTEND_GOOGLE_ERROR_REDIRECT_URL=http://127.0.0.1:5173/auth/login

PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_DEBUG_RETURN_TOKEN=false
FRONTEND_PASSWORD_RESET_URL=http://127.0.0.1:5173/auth/reset-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<smtp-username>
SMTP_PASSWORD=<smtp-password-or-app-password>
SMTP_FROM_EMAIL=noreply@study-room.local
SMTP_FROM_NAME=Study-Room
SMTP_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
